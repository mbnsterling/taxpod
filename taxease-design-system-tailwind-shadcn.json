{
  "design_system": {
    "name": "emerald-glass-saas",
    "stack": {
      "css_framework": "tailwindcss",
      "component_library": "shadcn-ui",
      "animation_library": "framer-motion",
      "icon_library": "lucide-react"
    },

    "layout": {
      "container": {
        "max_width": "1200px",
        "padding_x": "px-6",
        "center": true
      },
      "sections": {
        "padding_y": ["py-20", "py-24", "py-32"],
        "max_content_width": "max-w-7xl",
        "center": "mx-auto"
      },
      "grid_patterns": {
        "hero": "grid lg:grid-cols-2 gap-16 items-center",
        "features": "grid md:grid-cols-2 lg:grid-cols-3 gap-8",
        "stats": "grid md:grid-cols-4 gap-8",
        "testimonials": "grid md:grid-cols-3 gap-8",
        "steps": "grid md:grid-cols-3 gap-10"
      }
    },

    "typography": {
      "font_family": "font-sans",
      "weights": {
        "regular": "font-medium",
        "bold": "font-bold",
        "extra_bold": "font-extrabold",
        "black": "font-black"
      },
      "sizes": {
        "hero": ["text-5xl", "md:text-7xl"],
        "section_title": ["text-3xl", "md:text-4xl"],
        "card_title": "text-xl",
        "body": "text-base",
        "small": "text-sm"
      }
    },

    "colors": {
      "background": {
        "primary": "#F8FAFC"
      },
      "brand": {
        "primary": "emerald",
        "shades": [
          "emerald-400",
          "emerald-500",
          "emerald-600",
          "emerald-800",
          "emerald-900"
        ]
      },
      "text": {
        "primary": "slate-900",
        "secondary": "slate-600",
        "muted": "slate-400"
      },
      "icon_gradients": {
        "blue": ["from-blue-500", "to-cyan-500"],
        "orange": ["from-orange-500", "to-amber-500"],
        "pink": ["from-pink-500", "to-rose-500"],
        "purple": ["from-purple-500", "to-indigo-500"]
      }
    },

    "background_effects": {
      "ambient_blobs": [
        {
          "position": "top-left",
          "size": "40%",
          "color": "bg-emerald-200",
          "blur": "blur-[120px]",
          "opacity": "opacity-30"
        },
        {
          "position": "bottom-right",
          "size": "40%",
          "color": "bg-blue-200",
          "blur": "blur-[100px]",
          "opacity": "opacity-20"
        },
        {
          "position": "top-right",
          "size": "30%",
          "color": "bg-amber-100",
          "blur": "blur-[150px]",
          "opacity": "opacity-10"
        }
      ]
    },

    "glassmorphism": {
      "card_background": "bg-white/60",
      "blur": "backdrop-blur-xl",
      "border": "border border-white/40",
      "shadow": "shadow-[0_8px_32px_rgba(31,38,135,0.07)]"
    },

    "radius": {
      "card": "rounded-3xl",
      "large_card": "rounded-[2.5rem]",
      "button": "rounded-xl",
      "icon": "rounded-xl"
    },

    "shadows": {
      "soft": "shadow-sm",
      "card": "shadow-[0_8px_32px_rgba(31,38,135,0.07)]"
    },

    "buttons": {
      "primary": {
        "base": "bg-emerald-800 text-white",
        "hover": "hover:bg-emerald-900",
        "radius": "rounded-xl",
        "padding": "px-6 py-3",
        "font": "font-bold"
      },
      "secondary": {
        "base": "bg-white text-slate-900 border border-slate-200",
        "hover": "hover:bg-slate-50",
        "radius": "rounded-xl",
        "padding": "px-6 py-3",
        "font": "font-bold"
      }
    },

    "cards": {
      "base": "rounded-3xl border bg-white/60 backdrop-blur-xl border-white/40 shadow-[0_8px_32px_rgba(31,38,135,0.07)]",
      "padding": "p-8"
    },

    "icons": {
      "container": {
        "size": "w-12 h-12",
        "radius": "rounded-xl",
        "display": "flex items-center justify-center"
      }
    },

    "navbar": {
      "base": "fixed top-0 w-full z-50",
      "background": "bg-white/60 backdrop-blur-lg",
      "border": "border-b border-white/40",
      "shadow": "shadow-sm"
    },

    "gradients": {
      "brand_text": "bg-gradient-to-r from-emerald-400 to-teal-500 bg-clip-text text-transparent",
      "logo": "bg-gradient-to-br from-emerald-500 to-teal-700",
      "icon_blue": "bg-gradient-to-br from-blue-500 to-cyan-500",
      "icon_orange": "bg-gradient-to-br from-orange-500 to-amber-500",
      "icon_pink": "bg-gradient-to-br from-pink-500 to-rose-500",
      "icon_purple": "bg-gradient-to-br from-purple-500 to-indigo-500"
    },

    "motion": {
      "library": "framer-motion",
      "philosophy": "very subtle, minimal movement, fast transitions",

      "transition": {
        "duration_fast": 0.2,
        "duration_normal": 0.35,
        "duration_slow": 0.6,
        "ease": "easeOut"
      },

      "variants": {
        "fade_in": {
          "initial": { "opacity": 0 },
          "animate": { "opacity": 1 },
          "transition": { "duration": 0.35 }
        },

        "fade_up": {
          "initial": {
            "opacity": 0,
            "y": 12
          },
          "animate": {
            "opacity": 1,
            "y": 0
          },
          "transition": {
            "duration": 0.35,
            "ease": "easeOut"
          }
        },

        "fade_down": {
          "initial": {
            "opacity": 0,
            "y": -12
          },
          "animate": {
            "opacity": 1,
            "y": 0
          },
          "transition": {
            "duration": 0.35
          }
        },

        "scale_in": {
          "initial": {
            "opacity": 0,
            "scale": 0.96
          },
          "animate": {
            "opacity": 1,
            "scale": 1
          },
          "transition": {
            "duration": 0.3
          }
        },

        "card_hover": {
          "whileHover": {
            "y": -6,
            "scale": 1.01
          },
          "transition": {
            "duration": 0.2
          }
        },

        "button_tap": {
          "whileTap": {
            "scale": 0.96
          }
        }
      },

      "stagger": {
        "container": {
          "animate": {
            "transition": {
              "staggerChildren": 0.08
            }
          }
        }
      },

      "recommended_usage": {
        "sections": "fade_up",
        "cards": "scale_in",
        "hero_content": "fade_up",
        "feature_grid": "stagger container",
        "buttons": "button_tap",
        "hover_cards": "card_hover"
      }
    },

    "spacing": {
      "section_gap": "gap-16",
      "card_gap": "gap-8",
      "large_margin": "mb-24"
    }
  }
}
