// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum TaxpayerType {
    INDIVIDUAL
    SOLE_TRADER
    COMPANY
    PARTNERSHIP
    NON_PROFIT
}

enum UserTaxpayerRole {
    OWNER
    ADMIN
    ACCOUNTANT
    VIEWER
}

enum IncomeType {
    SALARY
    FREELANCE
    RENTAL
    BUSINESS
    INVESTMENT
    DIGITAL_ASSET_GAIN
    DIGITAL_ASSET_BUSINESS
    OTHER
}

enum SupplyCategory {
    STANDARD
    ZERO_RATED
    EXEMPT
}

enum DigitalAssetCapacity {
    TRADING
    INVESTMENT
}

enum TaxType {
    PIT
    VAT
    CIT
    CGT
    DEVELOPMENT_LEVY
    WHT
}

enum ReturnStatus {
    DRAFT
    READY_TO_FILE
    FILED
    AMENDED
    CANCELLED
}

enum PeriodType {
    ANNUAL
    MONTHLY
    QUARTERLY
}

enum PaymentStatus {
    PENDING
    SUCCESS
    FAILED
}

enum PaymentMethod {
    CARD
    BANK_TRANSFER
    USSD
    CASH
    WALLET
    OTHER
}

// ─────────────────────────────────────────────
// AUTH MODELS (NextAuth)
// ─────────────────────────────────────────────

model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    refresh_token_expires_in Int?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?

    // Credentials-based auth fields
    passwordHash              String?
    verificationToken         String?
    verificationTokenExpires  DateTime?
    resetPasswordToken        String?
    resetPasswordTokenExpires DateTime?

    accounts        Account[]
    sessions        Session[]
    taxpayerMembers TaxpayerUser[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// TAXPAYER PROFILE & ACCESS CONTROL
// ─────────────────────────────────────────────

/// Central tax subject: represents both individuals and businesses.
model Taxpayer {
    id            String       @id @default(cuid())
    type          TaxpayerType
    displayName   String
    tin           String?      @unique
    countryCode   String       @default("NG")
    residentState String?

    // Small enterprise classification (NTA 2025: turnover ≤ ₦100m, fixed assets ≤ ₦250m)
    annualTurnover    Decimal? @db.Decimal(20, 2)
    fixedAssetsValue  Decimal? @db.Decimal(20, 2)
    isSmallEnterprise Boolean  @default(false)
    isMultinational   Boolean  @default(false)

    // VAT profile
    hasVATRegistration  Boolean   @default(false)
    vatRegistrationDate DateTime?

    users                 TaxpayerUser[]
    incomeEntries         IncomeEntry[]
    expenseEntries        ExpenseEntry[]
    taxReturns            TaxReturn[]
    digitalAssetPositions DigitalAssetPosition[]
    pitBandConfigs        PITBandConfig[]
    vatConfigs            VATConfig[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

/// Join table: grants a User access to a Taxpayer profile with a specific role.
model TaxpayerUser {
    id         String           @id @default(cuid())
    userId     String
    taxpayerId String
    role       UserTaxpayerRole

    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    taxpayer Taxpayer @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())

    @@unique([userId, taxpayerId])
}

// ─────────────────────────────────────────────
// INCOME & EXPENSE ENTRIES
// ─────────────────────────────────────────────

/// Tracks individual income events with PIT and VAT attributes.
model IncomeEntry {
    id          String  @id @default(cuid())
    taxpayerId  String
    taxReturnId String?

    taxYear     Int
    occurredAt  DateTime
    incomeType  IncomeType
    description String?

    grossAmount Decimal @db.Decimal(20, 2)
    currency    String  @default("NGN")

    // VAT attributes (NTA 2025)
    isVatable          Boolean        @default(false)
    vatCollectedAmount Decimal?       @db.Decimal(20, 2)
    supplyCategory     SupplyCategory @default(STANDARD)

    taxpayer  Taxpayer   @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)
    taxReturn TaxReturn? @relation(fields: [taxReturnId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([taxpayerId, taxYear])
}

/// Tracks business expenses with VAT deductibility flags per NTA 2025.
model ExpenseEntry {
    id          String  @id @default(cuid())
    taxpayerId  String
    taxReturnId String?

    taxYear     Int
    occurredAt  DateTime
    description String?

    amount   Decimal @db.Decimal(20, 2)
    currency String  @default("NGN")

    // VAT deductibility (NTA 2025: non-deductible where VAT should have been charged but wasn't)
    isBusinessExpense Boolean  @default(true)
    shouldHaveVAT     Boolean  @default(false)
    vatPaidAmount     Decimal? @db.Decimal(20, 2)
    vatDocumented     Boolean  @default(false)

    taxpayer  Taxpayer   @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)
    taxReturn TaxReturn? @relation(fields: [taxReturnId], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([taxpayerId, taxYear])
}

// ─────────────────────────────────────────────
// DIGITAL ASSETS
// ─────────────────────────────────────────────

/// Digital/virtual asset position for NTA 2025 CGT treatment.
model DigitalAssetPosition {
    id          String               @id @default(cuid())
    taxpayerId  String
    capacity    DigitalAssetCapacity
    assetSymbol String

    acquisitionDate  DateTime
    acquisitionCost  Decimal   @db.Decimal(20, 2)
    disposalDate     DateTime?
    disposalProceeds Decimal?  @db.Decimal(20, 2)
    realisedGainLoss Decimal?  @db.Decimal(20, 2)

    taxpayer Taxpayer @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([taxpayerId, assetSymbol])
}

// ─────────────────────────────────────────────
// TAX RETURNS / FILINGS
// ─────────────────────────────────────────────

/// A tax return/filing for a specific tax type and period.
model TaxReturn {
    id         String     @id @default(cuid())
    taxpayerId String
    taxType    TaxType
    periodType PeriodType

    taxYear     Int
    periodStart DateTime
    periodEnd   DateTime

    status    ReturnStatus @default(DRAFT)
    filedAt   DateTime?
    reference String?      @unique

    // JSON blob storing calculator output: band breakdown, effective rate, notes, etc.
    summaryJson Json?

    taxpayer       Taxpayer       @relation(fields: [taxpayerId], references: [id], onDelete: Cascade)
    incomeEntries  IncomeEntry[]
    expenseEntries ExpenseEntry[]
    payments       TaxPayment[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([taxpayerId, taxType, taxYear])
}

// ─────────────────────────────────────────────
// TAX PAYMENTS
// ─────────────────────────────────────────────

/// Records a payment made against a tax return.
model TaxPayment {
    id          String        @id @default(cuid())
    taxReturnId String
    amount      Decimal       @db.Decimal(20, 2)
    currency    String        @default("NGN")
    status      PaymentStatus @default(PENDING)
    method      PaymentMethod

    paidAt            DateTime?
    providerReference String?
    metadata          Json?

    taxReturn TaxReturn @relation(fields: [taxReturnId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([taxReturnId])
}

// ─────────────────────────────────────────────
// TAX CONFIGURATION (DB-backed rules)
// ─────────────────────────────────────────────

/// PIT progressive band configuration per tax year.
/// Allows law changes to be applied without code deployments.
model PITBandConfig {
    id          String   @id @default(cuid())
    taxYear     Int
    lowerBound  Decimal  @db.Decimal(20, 2)
    upperBound  Decimal? @db.Decimal(20, 2)
    rate        Decimal  @db.Decimal(5, 4)
    description String?

    // Optional: scoped to a specific taxpayer's custom override (null = global default)
    taxpayerId String?
    taxpayer   Taxpayer? @relation(fields: [taxpayerId], references: [id], onDelete: SetNull)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([taxYear])
}

/// VAT configuration per tax year (singleton row per year for global defaults).
model VATConfig {
    id                    String  @id @default(cuid())
    taxYear               Int     @unique
    standardRate          Decimal @db.Decimal(5, 4)
    registrationThreshold Decimal @db.Decimal(20, 2)

    // Optional: scoped override (null = global default)
    taxpayerId String?
    taxpayer   Taxpayer? @relation(fields: [taxpayerId], references: [id], onDelete: SetNull)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

/// Zero-rated VAT supply categories aligned with NTA 2025.
model ZeroRatedCategory {
    id          String @id @default(cuid())
    taxYear     Int
    code        String
    description String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([taxYear, code])
    @@index([taxYear])
}
